{
    "name": "enorasis-core",
    "version": "0.1.5",
    "description": "Human vision for micro:bit V2 only: browser machine learning sends class labels over Bluetooth to your blocks.",
    "license": "MIT",
    "dependencies": {
        "core": "*",
        "bluetooth": "*"
    },
    "files": [
        "README.md",
        "enorasisCore.ts",
        "docs/start.md",
        "docs/last-class.md",
        "docs/class-is.md",
        "docs/on-class-received.md",
        "docs/on-class-name-received.md",
        "docs/on-connected.md",
        "docs/on-disconnected.md",
        "_locales/en/enorasis-core-strings.json",
        "_locales/el/enorasis-core-strings.json"
    ],
    "testFiles": [
        "test.ts"
    ],
    "public": true,
    "supportedTargets": [
        "microbit"
    ],
    "disablesVariants": [
        "mbdal"
    ],
    "preferredEditor": "blocksprj",
    "yotta": {
        "config": {
            "microbit-dal": {
                "bluetooth": {
                    "enabled": 1
                }
            }
        }
    }
}
