{
    "name": "enorasis-core",
    "version": "0.1.3",
    "description": "Human vision for micro:bit v2: browser machine learning sends class labels over BLE to MakeCode blocks.",
    "license": "MIT",
    "icon": "./icon.png",
    "dependencies": {
        "core": "*",
        "bluetooth": "*"
    },
    "files": [
        "README.md",
        "APPROVAL-CHECKLIST.md",
        "LICENSE.txt",
        "icon.png",
        "enorasisCore.ts",
        "test.ts",
        "docs/start.md",
        "docs/last-class.md",
        "docs/class-is.md",
        "docs/on-class-received.md",
        "docs/on-class-name-received.md",
        "docs/on-connected.md",
        "docs/on-disconnected.md",
        "_locales/en/enorasis-core-strings.json",
        "_locales/el/enorasis-core-strings.json"
    ],
    "public": true,
    "supportedTargets": [
        "microbit"
    ],
    "preferredEditor": "blocksprj",
    "yotta": {
        "config": {
            "microbit-dal": {
                "bluetooth": {
                    "enabled": 1
                }
            }
        }
    }
}
