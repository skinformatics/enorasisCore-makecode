{
    "name": "enorasis-core",
    "version": "0.1.1",
    "description": "enorasisCore: receive AI / machine learning class labels from the browser over BLE (micro:bit v2)",
    "license": "MIT",
    "dependencies": {
        "core": "*",
        "bluetooth": "*"
    },
    "files": [
        "README.md",
        "LICENSE.txt",
        "icon.png",
        "enorasisCore.ts",
        "test.ts",
        "_locales/en/enorasis-core-strings.json",
        "_locales/el/enorasis-core-strings.json"
    ],
    "public": true,
    "supportedTargets": [
        "microbit"
    ],
    "preferredEditor": "blocksprj",
    "yotta": {
        "config": {
            "microbit-dal": {
                "bluetooth": {
                    "enabled": 1
                }
            }
        }
    }
}
